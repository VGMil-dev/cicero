# -----------------------------------------------------------------------------
# CICERO - plantilla de variables de entorno para Desarrollo Local (@cicero/web)
# Copia este archivo como '.env.local' y actualiza los valores según corresponda.
# -----------------------------------------------------------------------------

# Supabase (Infraestructura de datos y persistencia)
# URL pública de la API de Supabase para comunicación directa desde el cliente
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
# Clave anónima para solicitudes públicas autenticadas por fila (RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Transformers.js / AI Inference Config
# Tipo de cuantización de hardware por defecto para reducir el consumo de RAM/GPU.
# Opciones recomendadas: 'q8', 'q4', 'fp32' (para máxima precisión si hay hardware disponible)
NEXT_PUBLIC_AI_MODEL_DTYPE=q8
